{
  "name": "chord-transposer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Build tooling for the Chord Transposer stylesheet and frontend bundle.",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i src/styles/tailwind.input.css -o src/static/tailwind.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i src/styles/tailwind.input.css -o src/static/tailwind.css --watch",
    "build:js": "vite build",
    "build": "npm run build:css && npm run build:js",
    "test:js": "vitest run",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
