# Flask application entry point.
FLASK_APP=src/app.py

# URL of the Gotenberg service used for PDF conversion.
# In docker compose this is the internal service address.
# On Railway, use the Gotenberg service's private address, e.g.
# http://gotenberg.railway.internal:3000
GOTENBERG_URL=http://localhost:3000

# Port the web server listens on.
PORT=5000

# Enable Flask debug mode (interactive debugger). Never set to 1 in production.
FLASK_DEBUG=0
